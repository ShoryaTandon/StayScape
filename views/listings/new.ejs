<% layout("./layouts/boilerplate") %>

<style>
  .preview-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    background: #e9ecef;
  }

  .preview-wrapper img {
    transition: transform 0.4s ease;
  }

  .preview-wrapper:hover img {
    transform: scale(1.03);
  }

  .preview-overlay {
    position: absolute;
    bottom: 0;
    width: 100%;
    padding: 0.75rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
    color: #fff;
    font-size: 0.9rem;
  }

  .form-control:focus {
    box-shadow: none;
    border-color: #212529;
  }

  input[type="file"]::file-selector-button {
    border: none;
    background: #212529;
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    margin-right: 1rem;
    cursor: pointer;
  }

  input[type="file"]::file-selector-button:hover {
    background: #000;
  }

  .card {
    animation: fadeUp 0.5s ease;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="container-fluid min-vh-100 bg-light py-4">
  <div class="row justify-content-center">
    <div class="col-xl-7 col-lg-8 col-md-10">

      <!-- Header -->
      <div class="mb-4">
        <a href="/listings" class="text-decoration-none text-muted small">
          ← Back to listings
        </a>
        <h2 class="fw-bold mt-2">Create a new listing</h2>
        <p class="text-muted mb-0">Add details that guests will love.</p>
      </div>

      <!-- Card -->
      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Image Preview -->
        <div class="preview-wrapper">
          <img
            id="previewImage"
            src="https://via.placeholder.com/1200x500?text=Listing+Preview"
            class="w-100"
            style="max-height: 40vh; object-fit: cover;"
            alt="Preview"
          >
          
        </div>

        <!-- Form -->
        <div class="card-body p-4 p-md-5">

          <form
            method="post"
            action="/listings/new"
            novalidate
            class="needs-validation"
            enctype="multipart/form-data"
          >

            <!-- Title -->
            <div class="mb-4">
              <label class="form-label text-uppercase small fw-semibold">
                Title
              </label>
              <input
                type="text"
                name="listing[title]"
                placeholder="Enter listing title"
                class="form-control form-control-lg border-0 border-bottom rounded-0 px-0"
                required
              >
              <div class="invalid-feedback">Enter valid title</div>
            </div>

            <!-- Description -->
            <div class="mb-4">
              <label class="form-label text-uppercase small fw-semibold">
                Description
              </label>
              <textarea
                name="listing[description]"
                placeholder="Describe your place"
                rows="4"
                class="form-control border-0 border-bottom rounded-0 px-0"
                required
                minlength="10"
              ></textarea>
              <div class="invalid-feedback">Description must be valid</div>
            </div>

            <!-- Image Upload -->
            <div class="mb-5">
              <label class="form-label text-uppercase small fw-semibold">
                Image
              </label>
              <input
                type="file"
                name="image"
                id="img"
                class="form-control border-0 border-bottom rounded-0 px-0"
                onchange="previewImage(event)"
              >
            </div>

            <!-- Price / Location / Country -->
            <div class="row g-4 mb-5">

              <div class="col-md-4">
                <label class="form-label text-uppercase small fw-semibold">
                  Price
                </label>
                <input
                  type="number"
                  min="1"
                  name="listing[price]"
                  placeholder="₹ Price"
                  class="form-control border-0 border-bottom rounded-0 px-0"
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label text-uppercase small fw-semibold">
                  Location
                </label>
                <input
                  type="text"
                  name="listing[location]"
                  placeholder="City / Area"
                  class="form-control border-0 border-bottom rounded-0 px-0"
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label text-uppercase small fw-semibold">
                  Country
                </label>
                <input
                  type="text"
                  name="listing[country]"
                  placeholder="Country"
                  class="form-control border-0 border-bottom rounded-0 px-0"
                  required
                >
              </div>

            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
              <a href="/listings" class="btn btn-outline-secondary rounded-pill px-4">
                Cancel
              </a>
              <button type="submit" class="btn btn-dark rounded-pill px-5">
                Create Listing
              </button>
            </div>

          </form>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function previewImage(event) {
    const img = document.getElementById("previewImage");
    const file = event.target.files[0];
    if (!file) return;
    img.src = URL.createObjectURL(file);
  }
</script>
