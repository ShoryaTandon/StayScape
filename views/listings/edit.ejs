<% layout("./layouts/boilerplate") %>

<style>
  .preview-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    background: #000;
  }

  .preview-wrapper img {
    transition: transform 0.4s ease;
  }

  .preview-wrapper:hover img {
    transform: scale(1.04);
  }

  .preview-overlay {
    position: absolute;
    bottom: 0;
    width: 100%;
    padding: 0.75rem 1.2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    color: #fff;
    font-size: 0.9rem;
  }

  .form-control:focus {
    box-shadow: none;
    border-color: #212529;
  }

  input[type="file"]::file-selector-button {
    border: none;
    background: #212529;
    color: #fff;
    padding: 0.45rem 1.1rem;
    border-radius: 20px;
    margin-right: 1rem;
    cursor: pointer;
  }

  input[type="file"]::file-selector-button:hover {
    background: #000;
  }

  .card {
    animation: fadeUp 0.45s ease;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section-label {
    letter-spacing: 0.08em;
  }
</style>

<div class="container-fluid min-vh-100 bg-light py-5">
  <div class="row justify-content-center">
    <div class="col-xl-7 col-lg-8 col-md-10">

      <!-- Header -->
      <div class="mb-4">
        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-muted small">
          ← Back to listing
        </a>
        <h2 class="fw-bold mt-2">Edit your listing</h2>
        <p class="text-muted mb-0">Make changes that guests will see.</p>
      </div>

      <!-- Card -->
      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Image Preview -->
        <div class="preview-wrapper">
          <img
            id="previewImage"
            src="<%= listing.image.url %>"
            class="w-100"
            style="max-height: 45vh; object-fit: cover;"
            alt="Listing Image"
          >
          
        </div>

        <!-- Form -->
        <div class="card-body p-4 p-md-5">

          <form
            method="post"
            action="/listings/<%= listing._id %>?_method=PUT"
            novalidate
            class="needs-validation"
            enctype="multipart/form-data"
          >

            <!-- Title -->
            <div class="mb-4">
              <label class="form-label text-uppercase small fw-semibold text-muted section-label">
                Title
              </label>
              <input
                type="text"
                class="form-control form-control-lg border-0 border-bottom rounded-0 px-0"
                name="listing[title]"
                value="<%= listing.title %>"
                required
              >
              <div class="invalid-feedback">Enter valid title</div>
            </div>

            <!-- Description -->
            <div class="mb-4">
              <label class="form-label text-uppercase small fw-semibold text-muted section-label">
                Description
              </label>
              <textarea
                class="form-control border-0 border-bottom rounded-0 px-0"
                name="listing[description]"
                rows="3"
                required
                minlength="60"
              ><%= listing.description %></textarea>
              <div class="invalid-feedback">
                Description must be at least 10 words
              </div>
            </div>

            <!-- Image Upload -->
            <div class="mb-5">
              <label class="form-label text-uppercase small fw-semibold text-muted section-label">
                Change Image
              </label>
              <input
                type="file"
                class="form-control border-0 border-bottom rounded-0 px-0"
                name="image"
                onchange="previewImage(event)"
              >
              
            </div>

            <!-- Price / Location / Country -->
            <div class="row g-4 mb-5">

              <div class="col-md-4">
                <label class="form-label text-uppercase small fw-semibold text-muted section-label">
                  Price
                </label>
                <input
                  type="number"
                  min="1"
                  class="form-control border-0 border-bottom rounded-0 px-0"
                  name="listing[price]"
                  value="<%= listing.price %>"
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label text-uppercase small fw-semibold text-muted section-label">
                  Location
                </label>
                <input
                  type="text"
                  class="form-control border-0 border-bottom rounded-0 px-0"
                  name="listing[location]"
                  value="<%= listing.location %>"
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label text-uppercase small fw-semibold text-muted section-label">
                  Country
                </label>
                <input
                  type="text"
                  class="form-control border-0 border-bottom rounded-0 px-0"
                  name="listing[country]"
                  value="<%= listing.country %>"
                  required
                >
              </div>

            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-between align-items-center pt-4 border-top">
              <a
                href="/listings/<%= listing._id %>"
                class="btn btn-outline-secondary rounded-pill px-4"
              >
                Cancel
              </a>

              <button
                type="submit"
                class="btn btn-dark rounded-pill px-5"
              >
                Save Changes
              </button>
            </div>

          </form>

        </div>
      </div>

    </div>
  </div>
</div>

<!-- Live Preview JS (unchanged) -->
<script>
  function previewImage(event) {
    const img = document.getElementById("previewImage");
    const file = event.target.files[0];
    if (!file) return;
    img.src = URL.createObjectURL(file);
  }
</script>
